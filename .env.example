# ─── ANTHROPIC ───────────────────────────────────────────────
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# ─── AUTH ────────────────────────────────────────────────────
# Any long random string — run: openssl rand -base64 32
JWT_SECRET=your-secret-here

# ─── NEON DATABASE ───────────────────────────────────────────
# Get from: https://console.neon.tech/
# Create a new project, copy the connection string
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# ─── VERCEL KV (Upstash Redis) ───────────────────────────────
# Auto-populated when you add Vercel KV storage in the Vercel dashboard
# Or get from: https://console.upstash.com/
KV_URL=redis://...
KV_REST_API_URL=https://xxx.upstash.io
KV_REST_API_TOKEN=xxx
KV_REST_API_READ_ONLY_TOKEN=xxx

# ─── RESEND (Email) ──────────────────────────────────────────
# Get from: https://resend.com/ — free up to 3,000 emails/month
# Also add and verify your sending domain in Resend dashboard
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@designsparring.com

# ─── STRIPE ──────────────────────────────────────────────────
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Create a recurring price in Stripe dashboard ($9/month)
# Products → Add product → $9 → Monthly → Copy price ID
STRIPE_PRICE_ID=price_...

# ─── APP ─────────────────────────────────────────────────────
# Your Vercel deployment URL (or localhost for dev)
NEXT_PUBLIC_URL=http://localhost:3000
